[t:0x0c0a,n:text]
{
	// Grandma Farmer
	[0x0000]
	{
		from = "Good day to you, dear stranger. Welcome to Pentachoron Garden.";
		to = "Buenos días, querido forastero. Bienvenido al Jardín Pentacorón.";
	}
	[0x0000]
	{
		from = "It's the loveliest piece of land right here along the Brook, isn't it? Our Farm is right in the Middle of the Garden.";
		to = "Es un lugar precioso, justo aquí, junto al arroyo, ¿verdad? Nuestra Granja está en medio del Jardín.";
	}
	[0x0000]
	{
		from = "Are you new to the Garden?
Well, there's basically three parts: we're in the Vale, which is the nicest part of it to have a walk. I recommend you to just follow the Brook down to the Inn - greet our junior if you see him there.
Then there's the Woods, and behind them lies the Mount. Be a bit careful if you wander through the Woods, and especially up on the Mount. Also, take some warm clothes with you, it's usually covered in snow up there.";
		to = "¿Eres nuevo en el Jardín?
Bueno, básicamente hay tres partes: estamos en el Valle, que es la parte más bonita para pasear. Te recomiendo que sigas el arroyo hasta la Posada; saluda a nuestro hijo si lo ves allí.
Luego está el Bosque, y detrás de él se encuentra el Monte. Ten un poco de cuidado si te adentras en el Bosque, y especialmente en la Monte. Además, lleva ropa de abrigo, ya que suele estar cubierto de nieve.";
	}
	[0x0000]
	{
		from = "Enjoy your time here, my dear! Life is too short to worry. Just have fun, young one.";
		to = "¡Disfruta de tu estancia aquí! La vida es demasiado corta para preocuparse. Diviértase, joven.";
	}

	// Mr. Farmer
	[0x0000]
	{
		from = "You won't find packmules like these anywhere else!";
		to = "¡No encontrarás mulas de carga como estas en ningún otro lugar!";
	}
	[0x0000]
	{
		from = "Hello there, welcome on our little homestead!";
		to = "¡Hola! ¡Bienvenidos a nuestra pequeña granja!";
	}
	[0x0000]
	{
		from = "My name is Mr. Farmer, I'm the farmer here. And the proud owner of these beautiful packmules. Look at these exemplars, what beautiful mules they are! So strong and always loyal. You won't find packmules like these anywhere else! You can rent them if you want!";
		to = "Me llamo Sr. Granjero, soy el granjero de aquí. Y el orgulloso dueño de estas hermosas mulas de carga. ¡Miren qué ejemplares! ¡Qué mulas tan hermosas! Tan fuertes y siempre leales. ¡No encontrarán mulas de carga como estas en ningún otro lugar! ¡Pueden alquilarlas si lo desean!";
	}
	[0x0000]
	{
		from = "Would you like to rent a packmule? You can keep it for your entire stay here in the Garden if you want.";
		to = "¿Le gustaría alquilar una mula de carga? Si lo desea, puede conservarla durante toda su estancia en el Jardín.";
	}

	// Mrs. Farmer
	[0x0000]
	{
		from = "Hello, and welcome to the Farm!";
		to = "¡Hola y bienvenidos a la Granja!";
	}
	[0x0000]
	{
		from = "Not sure where to go from here? The Flip-Flop is broken currently, but don't worry, we are right in the middle of the Garden, so everything is pretty close anyways. About the Flip-Flop best ask Mr. Miller up at the Mill.";
		to = "¿No sabes qué hacer ahora? El Volteador está roto, pero no te preocupes, estamos justo en medio del Jardín, así que todo está bastante cerca. Para saber más sobre los Volteadores, pregúntale al Sr. Molinero en el Molino.";
	}
	[0x0000]
	{
		from = "If you follow the Brook upstream, you'll get to the Mill soon enough. And the way there is literally a walk in the Park. You'll see, it's beautiful. And no wild animals to be afraid of - though if you see a phrak queen kindly squash it, we don't want these critters to build nests!";
		to = "Si sigues el arroyo río arriba, llegarás al Molino enseguida. El camino es literalmente un paseo por el parque. Ya verás, es precioso. Y no hay animales salvajes a los que temer; aunque si ves una Reina Phrak, aplástala, ¡No queremos que esos bichos construyan nidos!";
	}
	[0x0000]
	{
		from = "Following the Brook downstream, you'll get through our Orchard, and will arrive at the Inn. Our junior's over there probably, hanging out with his friends instead of making himself useful. Anyways, the Orchard is full of cute little gremals but be careful with the bigger ones. Been bitten recently.";
		to = "Siguiendo el Arroyo río abajo, pasarás por nuestro Huerto y llegarás a la Posada. Nuestro hijo probablemente esté por allí, pasando el rato con sus amigos en lugar de ser útil. En fin, el Huerto está lleno de pequeños gremals adorables, pero ten cuidado con los más grandes. Me mordieron hace poco.";
	}
	[0x0000]
	{
		from = "Heading north you will leave the Vale and the Brook and enter the Woods. This way lies our Graveyard, not very pleasant because it's quite swampy. Also not pleasant because it's haunted by an Ancient Corpse who keeps waking up our forefathers.
Passing through it you will arrive at the Witch's Cottage. If you want to know why our graveyard is at the ugliest place in the Garden, ask them. Apparently it was old Walburga herself who decided this back then.";
		to = "Si te diriges al norte, dejarás el Valle y el Arroyo y entrarás en el Bosque. Por ahí se encuentra nuestro Cementerio, un lugar poco agradable por lo pantanoso que es. Tampoco es agradable porque está embrujado por un Cadáver Antiguo que no deja de despertar a nuestros antepasados.
Tras atravesarlo, llegarás a la Cabaña de la Bruja. Si quieres saber por qué nuestro cementerio está en el lugar más feo del Jardín, pregúntales. Al parecer, fue la mismísima Walburga quien lo decidió en aquel entonces.";
	}
	[0x0000]
	{
		from = "The way to the Dwarven Smithy up on the Mount also leads throught the Woods, naturally. You can get there when you continue west from here. The way leads right through the Rat's Den, however, so I'd look for a different way up the Mount if I were you. If you do go through the Rat's Den, I'd be thankful for every hairy beast you kill. Those rats are a real plague to our Farm...";
		to = "El camino a la Herrería Enana en la Monte también atraviesa el bosque, como es lógico. Puedes llegar si sigues hacia el oeste desde aquí. Sin embargo, el camino pasa justo por la Guarida de las Ratas, así que yo buscaría otra ruta para subir a la montaña. Si pasas por la Guarida de las Ratas, te estaría agradecería por cada rata que mates. ¡Esas ratas son una verdadera plaga para nuestra Granja!";
	}
	[0x0000]
	{
		from = "Enjoy your stay in the Garden!";
		to = "¡Disfruta de tu estadía en el Jardín!";
	}
}
