[t:0x0c0a,n:text]
{
	// Companions generic
	[0x0000]
	{
		from = "Yay let's go!";
		to = "¡Sí, vamos!";
	}
	[0x0000]
	{
		from = "Wait, what?";
		to = "Espera, ¿qué?";
	}
	[0x0000]
	{
		from = "Pff then not!";
		to = "¡Pff, entonces no!";
	}
	[0x0000]
	{
		from = "No hard feelings mate... Wanna go together again?";
		to = "Sin sentimientos duros camarada ... ¿Quieres ir juntos de nuevo?";
	}

	// Bailey
	[0x0000]
	{
		from = "Holla visitor, wouldst thou like some company?
mine own name is Bailey, i'm the daughter of this house, and bor'd to death of serving Shrump Ale to the grannies' club of wannabe historians.  Prithee taketh me with thee!";
		to = "Saludos, visitante, ¿le gustaría compañía?
Me llamo Bailey, soy la hija de esta casa y estoy harta de servir cerveza Shrump al club de abuelitas aspirantes a historiadoras. ¡Por favor, llevadme con vos!";
	}
	[0x0000]
	{
		from = "Prithee taketh me with thee!";
		to = "¡Por favor, llevadme con vos!";
	}
	[0x0000]
	{
		from = "Holla visitor! mine own name is Bailey, i'm the daughter of this house, and bor'd to death of serving Shrump Ale to the grannies' club of wannabe historians.";
		to = "¡Saludos, visitante! Me llamo Bailey, soy la hija de esta casa y estoy harta de servir cerveza Shrump al club de abuelitas aspirantes a historiadoras.";
	}

    // Boyler
	[0x0000]
	{
		from = "Greedings, stranger. My name ish Boyler Smyth, son of Blade.
Would you like combany during your shtay here? It would be my bleashure to show you the Dwarven Smithy, and a handy combat maych ish always useful.
Of course I would like to earn some pogged money; I wand to buy a new anvil for my homeworg.";
		to = "Saludos, forrasterro. Me llamo Boyler Smyth, hijo de Blade.
¿Le gustarría que le acompañarra durrante su estancia? Serría un placer mostrarte la herrería enana, y una buena ronda de camorra siempre viene bien.
Por supuesto, me gustarría ganar algo de dinero; quiero comprarr un nuevo yunque para mi tallerr.";
	}
	[0x0000]
	{
		from = "Would you like combany during your shtay here? It would be my bleashure to show you the Dwarven Smithy, and a handy combat maych ish always useful.";
		to = "¿Le gustarría que le acompañarra durrante su estancia? Serría un placer mostrarte la herrería enana, y una buena ronda de camorra siempre viene bien.";
	}
	[0x0000]
	{
		from = "Of course I would like to earn some pogged money; I wand to buy a new anvil for my homeworg.";
		to = "Por supuesto, me gustarría ganar algo de dinero; quiero comprarr un nuevo yunque para mi tallerr.";
	}
	[0x0000]
	{
		from = "Greedings, stranger. My name ish Boyler Smyth, son of Blade.";
		to = "Saludos, forrasterro. Me llamo Boyler Smyth, hijo de Blade.";
	}

    // Kale
	[0x0000]
	{
		from = "Hello. I am Kale, Kale Farmer. I'm a farmer.";
		to = "Hola. Soy Kale, Granjero Kale. Soy agricultora.";
	}
	[0x0000]
	{
		from = "My parents are farmers. We live on the Farm.";
		to = "Mis padres son granjeros. Vivimos en la Granja.";
	}
	[0x0000]
	{
		from = "Wanna see the Farm? I can show you. I can show you around the whole Garden if you want.
But you would need to pay my bill...";
		to = "¿Quieres ver la Granja? Te la puedo enseñar. Si quieres, te puedo mostrar todo el Jardín.
Pero tendrías que pagarme la cuenta...";
	}
	[0x0000]
	{
		from = "I'm afraid I have ordered too many Shrump Ales and my money ran out. Math's a bitch right? My friends here have no money left either. Mom n pop will be angry with me again. Please bail me out? You can rely on my strong arm for as long as you stay.";
		to = "Me temo que pedí demasiadas Cervezas Shrump y me quedé sin dinero. Las matemáticas son una mierda, ¿verdad? Mis amigos aquí tampoco tienen dinero. Mamá y papá se enfadarán conmigo otra vez. ¿Puedes ayudarme? Puedes contar con mi fuerza mientras te quedes.";
	}
	[0x0000]
	{
		from = "Please bail me out? You can rely on my strong arm for as long as you stay.";
		to = "¿Puedes ayudarme? Puedes contar con mi fuerza mientras te quedes.";
	}
	[0x0000]
	{
		from = "I'm afraid I have ordered too many Shrump Ales and my money ran out. Math's a bitch right?";
		to = "Me temo que pedí demasiadas Cervezas Shrump y me quedé sin dinero. Las matemáticas son una mierda, ¿verdad?";
	}

    // Millie
	[0x0000]
	{
		from = "Hello mate, fancy some company for taking a stroll through the Garden? I'd love to join you. I'd also love some pocket money, wink wink nod nod.";
		to = "Hola, ¿te apetece dar un paseo por el Jardín de compañia? Me encantaría acompañarte. También me encantaría algo de dinero, guiño, guiño, codo, codo.";
	}
	[0x0000]
	{
		from = "Fancy some company for taking a stroll through the Garden? I'd love to join you. I'd also love some pocket money, wink wink nod nod.";
		to = "¿te apetece dar un paseo por el Jardín con algo de compañia? Me encantaría acompañarte. También me encantaría algo de dinero, guiño, guiño, codo, codo.";
	}
	[0x0000]
	{
		from = "I'd really love some pocket money, wink wink nod nod.";
		to = "Me encantaría algo de dinero, guiño, guiño, codo, codo.";
	}
	[0x0000]
	{
		from = "Hello mate, howya doin!";
		to = "Hola camarada, ¿cómo estás?";
	}

    // Zend
	[0x0000]
	{
		from = "What do we have here, a visitor! Have money?
I'm Zend Witch, the grandson of Demelza the Witch. Fancy a skilled nature mage on your side exploring the Garden? I wanna buy a new cauldron for my homework, so for a little bit of gold I'm all yours!";
		to = "¡Vaya, un visitante! ¿Tienes dinero?
Soy Zend Witch, nieto de Demelza la Bruja. ¿Te gustaría tener a un mago de la naturaleza a tu lado explorando el Jardín? Quiero comprar un caldero nuevo para mis deberes, ¡así que por un poco de oro soy todo tuyo!";
	}
	[0x0000]
	{
		from = "Fancy a skilled nature mage on your side exploring the Garden? I wanna buy a new cauldron for my homework, so for a little bit of gold I'm all yours!";
		to = "¿Te gustaría tener a un mago de la naturaleza a tu lado explorando el Jardín? Quiero comprar un caldero nuevo para mis deberes, ¡así que por un poco de oro soy todo tuyo!";
	}
	[0x0000]
	{
		from = "No money? Pshah! Begone.";
		to = "¿No tienes dinero? ¡Bah! ¡Lárgate!";
	}
	[0x0000]
	{
		from = "What do we have here, a visitor! I'm Zend Witch, the grandson of Demelza the Witch.";
		to = "¡Vaya, un visitante! Soy Zend Witch, nieto de Demelza la Bruja.";
